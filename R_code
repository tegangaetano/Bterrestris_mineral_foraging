#LOAD PACKAGES####
#General
library(readxl) #read in .xls and .xlsx files
library(tidyverse) #load core tidyverse packages
library(dplyr) #data manipulation and organisation

#Visualization
library(ggplot2) #data visualization - part of tidyverse

#Analysis
install.packages('car')
library(car) #ANOVA and other regression analysis
library(glmmTMB) #linear and generalised linear models
library(performance) #assess model quality
library(DHARMa) #residual diagnostics; https://steffilazerte.ca/posts/dharma/

#Post-hoc tests 
library(emmeans) #obtain estimated marginal means for linear and mixed models

#LOAD DATA####
#Import data as Excel spreadsheet
all_data <- read_excel("C:/Users/r01tg22/Desktop/Behav_exp/all_data.xlsx")

#Reduce dataset to desired columns
all_data <- all_data[c('date', 'observer', 'duration_mins',
                           'temp_C', 'humidity',
                           'colony', 'arena',
                           'analyte', 'concentration', 'PPM',
                           'evap-corrected_per_bee_mL', 
                           'total_consumed_mL')]

Behav_data <- as.data.frame(Behav_data)

#Convert data to numeric
Behav_data$PPM <- as.numeric(all_data$PPM)
Behav_data$new_NCV <- as.numeric(all_data$new_NCV)

#Create new PPM as a factor
Behav_data$fPPM <- as.factor(all_data$PPM)

#Change the decimal humidity to a percent
all_data$humidity_percent <- all_data$humidity * 100

#Convert data to factor
all_data$observer <- as.factor(all_data$observer)
all_data$arena <- as.factor(all_data$arena)
all_data$colony <- as.factor(all_data$colony)
all_data$analyte <- as.factor(all_data$analyte)
all_data$concentration <- factor(all_data$concentration, 
                                   levels = c('control', 
                                              'low', 
                                              'low_medium',
                                              'medium',
                                              'medium_high',
                                              'high'))
#FILTER DATA####
#Filter analyte data
Na_data <- all_data %>%
  filter(analyte == 'Na')

Ca_data <- all_data %>%
  filter(analyte == 'Ca')

K_data <- all_data %>%
  filter(analyte == 'K')

Mg_data <- all_data %>%
  filter(analyte == 'Mg')

#ANALYSIS####
#Climatic Model

#Using LMM with humidity and temperature and their interaction as continuous variables predicting per bee consumption of
#test solution (mL) and date and colony as random effects.
clim_model <- glmmTMB(evap-corrected_per_bee_mL ~ 
                      scale(temp_C) * scale(humidity_percent) +
                        (1 | date) +
                      (1 | colony),
                      family = beta_family,
                        data = all_data)

#Check goodness of fit
sim_Output <- simulateResiduals(clim_model, n = 250)

plot(sim_Output)
testResiduals(sim_Output) 

summary(clim_model)
Anova(clim_model)

#Create interaction plot with humidity on the x axis
interact_clim <- interact_plot(clim_model, pred = humidity_percent, modx = temp_C, 
              interval = TRUE, int.width = 0.6,
              plot.points = TRUE,
              data = all_data,
              x.label = 'Humidity (%)',
              y.label = 'Average Consumption per Bee (mL)',
              legend.main = 'Temperature (C)',
              main = '') +
  theme_classic()

interact_clim + theme(axis.text = element_text(size = 14),
                   axis.title = element_text(size = 16))

#ANALYSIS BY ANALYTE####
#Sodium (Na)####
#Using LMM with PPM as a categorical factor explanatory variable predicting normalised consumption value (NCV)
#and date and colony as random effects.
Na_NCV_model <- glmmTMB(NCV_mL ~ fPPM + 
                         (1 | date) +
                         (1 | colony),
                        family = gaussian, 
                       data = Na_data)

#Using LMM with PPM as a continuous explanatory variable fit with a quadratic term to predict NCV with date and colony
#With three terms
Na_NCV_poly <- glmmTMB(NCV_mL ~ poly(PPM, 3) +
                      (1 | date) +
                        (1 | colony),
                      family = gaussian, 
                      data = Na_data)

#With two terms
Na_NCV_poly_red <- glmmTMB(NCV_mL ~ poly(PPM, 2) +
                            (1 | date) +
                            (1 | colony),
                          family = gaussian, 
                          data = Na_data)

#With one term
Na_NCV_poly_red2 <- glmmTMB(NCV_mL ~ poly(PPM, 1) +
                            (1 | date) +
                            (1 | colony),
                          family = gaussian, 
                          data = Na_data)

#Check model assumptions
check_model(Na_NCV_model) 
check_model(Na_NCV_poly) 
check_model(Na_NCV_poly_red) 
check_model(Na_NCV_poly_red2) 

#Dharma tests
sim_Output <- simulateResiduals(Na_NCV_model, n = 250) 
sim_Output <- simulateResiduals(Na_NCV_poly, n = 250) 
sim_Output <- simulateResiduals(Na_NCV_poly_red, n = 250) 
sim_Output <- simulateResiduals(Na_NCV_poly_red2, n = 250) 

#Check model fit
AIC(Na_NCV_poly, Na_NCV_poly_red, Na_NCV_poly_red2)

plot(sim_Output)
testResiduals(sim_Output)

summary(Na_NCV_model)
Anova(Na_NCV_model)

summary(Na_NCV_poly_red)
Anova(Na_NCV_poly_red)

#Examine contrasts
Na_contrasts <- emmeans(Na_NCV_model, pairwise ~ fPPM, type = 'response', adjust = 'mvt')
Na_contrasts    

#Graph model predictions
Na_labels = c('Control\n(0 ppm)', 'Low\n(50 ppm)', 'Low-medium\n(500 ppm)', 
              'Medium\n(1,000 ppm)', 
           'Medium-high\n(2,000 ppm)', 'High\n(4,000 ppm)')

Na_NCV_pred <- ggpredict(Na_NCV_model, terms = 'fPPM [all]')
Na_gg_plot <- ggplot(Na_NCV_pred, aes(x, predicted)) +
  geom_point(data = Na_data, colour = 'skyblue', size = 4,
             alpha = 0.5,
             aes(y = NCV_mL, x = fPPM)) +
  geom_pointrange(aes(ymin = conf.low,
                      ymax = conf.high), colour = 'steelblue',
                  size = 1) +
  geom_hline(yintercept = mean(Na_NCV_pred$predicted), linetype = 'dashed') +
  xlab('Concentration') +
  ylab('NCV (0 = mean of predicted values)') +
theme_classic()

Na_gg_plot + theme(axis.text = element_text(size = 12),
                   axis.title = element_text(size = 14)) +
  scale_x_discrete(label = Na_labels) +
  scale_y_continuous(limits = c(-0.1, 0.4))

Na_NCV_poly_pred <- ggpredict(Na_NCV_poly_red, terms = 'PPM')
Na_gg_poly_plot <- ggplot(Na_NCV_poly_pred,
                         aes(x, predicted)) +
  geom_point(data = Na_data, colour = 'skyblue', size = 4,
             alpha = 0.5,
             aes(y = NCV_mL, x = PPM)) +
  geom_pointrange(aes(xmin = conf.low,
                      xmax = conf.high), colour = 'steelblue',
                  size = 1) +
  geom_ribbon(aes(ymin = conf.low, ymax = conf.high),
              fill = 'skyblue', alpha = 0.25,
              linetype = 0) +
  geom_line(colour = 'steelblue') +
  geom_hline(yintercept = mean(Na_NCV_pred$predicted), linetype = 'dashed') +
  theme_classic() +
  xlab('Concentration (ppm w/v)') +
  ylab('NCV (0 = mean of predicted values)') +
  ylim(-0.1, 0.4) +
  guides(fill = FALSE)

Na_gg_poly_plot + theme(axis.text = element_text(size = 12),
                       axis.title = element_text(size = 14))

